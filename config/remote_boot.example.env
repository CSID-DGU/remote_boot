# Targets to wake during boot.
# Accepts names separated by spaces or commas, for example:
# REMOTE_BOOT_TARGETS="FARM1 LAB1"
# REMOTE_BOOT_TARGETS="all-farm,LAB1"
REMOTE_BOOT_FARM_TARGETS="FARM1 FARM2 FARM6 FARM7 FARM8 FARM9"
REMOTE_BOOT_LAB_TARGETS="LAB1 LAB2 LAB3 LAB4 LAB5 LAB6 LAB7 LAB8 LAB9"
REMOTE_BOOT_TARGETS="all"

# Optional delay after boot before packets are sent.
REMOTE_BOOT_PRE_DELAY_SECONDS=0

# Targets sent first. After REMOTE_BOOT_SECONDARY_DELAY_SECONDS, the remaining
# selected targets are sent.
REMOTE_BOOT_PRIORITY_TARGETS="FARM1 LAB1"
REMOTE_BOOT_ENABLE_GATE=true
REMOTE_BOOT_GATE_TIMEOUT_SECONDS=360
REMOTE_BOOT_GATE_POLL_SECONDS=20
REMOTE_BOOT_SECONDARY_DELAY_SECONDS=0
REMOTE_BOOT_ENABLE_CONTAINER_RESTART=true
REMOTE_BOOT_CONTAINER_RESTART_TIMEOUT_SECONDS=600
REMOTE_BOOT_CONTAINER_RESTART_POLL_SECONDS=20
# Leave empty to use ansible.cfg/default inventory resolution.
# REMOTE_BOOT_ANSIBLE_INVENTORY="/etc/ansible/inventory.ini"

# Broadcast IPs passed to wakeonlan -i.
REMOTE_BOOT_FARM_BROADCAST_IP="192.168.2.255"
REMOTE_BOOT_LAB_BROADCAST_IP="192.168.1.255"

# Wake-on-LAN MAC addresses. Keep real values only in remote_boot.local.env.
REMOTE_BOOT_MAC_FARM1=""
REMOTE_BOOT_MAC_FARM2=""
REMOTE_BOOT_MAC_FARM6=""
REMOTE_BOOT_MAC_FARM7=""
REMOTE_BOOT_MAC_FARM8=""
REMOTE_BOOT_MAC_FARM9=""
REMOTE_BOOT_MAC_LAB1=""
REMOTE_BOOT_MAC_LAB2=""
REMOTE_BOOT_MAC_LAB3=""
REMOTE_BOOT_MAC_LAB4=""
REMOTE_BOOT_MAC_LAB5=""
REMOTE_BOOT_MAC_LAB6=""
REMOTE_BOOT_MAC_LAB7=""
REMOTE_BOOT_MAC_LAB8=""
REMOTE_BOOT_MAC_LAB9=""

# Required NFS mounts checked on the host with df -h.
REMOTE_BOOT_FARM_REQUIRED_MOUNT="100.100.100.120:/volume1/share"
REMOTE_BOOT_LAB_REQUIRED_MOUNT="100.100.100.100:/294t/dcloud/share"

# Test container settings for boot health checks.
REMOTE_BOOT_TEST_USERNAME="boot_test"
REMOTE_BOOT_TEST_GROUP="boot_test"
REMOTE_BOOT_TEST_UID=10000
REMOTE_BOOT_TEST_GID=10000
REMOTE_BOOT_TEST_PASSWORD="ailab2260"
REMOTE_BOOT_TEST_CONTAINER_NAME_PREFIX="boot_test_probe"
REMOTE_BOOT_TEST_IMAGE_REPOSITORY="dguailab"
REMOTE_BOOT_TEST_IMAGE="pytorch"
REMOTE_BOOT_TEST_VERSION="latest"
REMOTE_BOOT_TEST_MEMORY="192g"
# %s is replaced with the numeric part of the server id.
# Examples: FARM1 -> /home/tako1/share/user-share/, LAB9 -> /home/tako9/share/user-share/
REMOTE_BOOT_TEST_SHARE_SOURCE_TEMPLATE="/home/tako%s/share/user-share/"
REMOTE_BOOT_TEST_SHARE_SOURCE_BASE="/home/tako"
REMOTE_BOOT_TEST_SHARE_SOURCE_SUFFIX="/share/user-share/"
REMOTE_BOOT_TEST_SHARE_TARGET="/home/"
REMOTE_BOOT_TEST_POST_CREATE_TIMEOUT_SECONDS=60
REMOTE_BOOT_TEST_POST_CREATE_POLL_SECONDS=5

# Optional installer settings.
REMOTE_BOOT_LOG_FILE="/var/log/remote-boot.log"
REMOTE_BOOT_LOG_ROTATE_COUNT=14
